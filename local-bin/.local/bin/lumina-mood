#!/usr/bin/env python3
from __future__ import annotations
import argparse, sys
from pathlib import Path
for p in (Path(__file__).resolve().parents[3] / "apps/lib", Path.home() / ".local/share/lumina/lib"):
    if p.exists(): sys.path.insert(0, str(p))
from lumina_core.mood import Mood, apply_mood, current_mood, detect_mood_from_wallpaper
p=argparse.ArgumentParser(prog="lumina-mood"); s=p.add_subparsers(dest="command", required=True)
sp=s.add_parser("set"); sp.add_argument("mood", choices=[m.value for m in Mood]); dp=s.add_parser("detect"); dp.add_argument("--wallpaper", required=True); s.add_parser("status"); a=p.parse_args()
if a.command == "status": print(current_mood().value)
elif a.command == "set": apply_mood(Mood(a.mood))
else: m=detect_mood_from_wallpaper(a.wallpaper).result(); apply_mood(m); print(m.value)
