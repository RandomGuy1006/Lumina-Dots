#!/usr/bin/env python3
from __future__ import annotations
import argparse, json, os, sys
from pathlib import Path
for p in (Path(__file__).resolve().parents[3] / "apps/lib", Path.home() / ".local/share/lumina/lib"):
    if p.exists(): sys.path.insert(0, str(p))
from lumina_core.theme import apply_theme, load_tokens, preview_tokens
from lumina_core.toasts import toast
p=argparse.ArgumentParser(prog="lumina-theme"); s=p.add_subparsers(dest="command", required=True)
ap=s.add_parser("apply"); ap.add_argument("--wallpaper"); ap.add_argument("--temperature", type=int, default=6500)
s.add_parser("reset"); pr=s.add_parser("preview"); pr.add_argument("path"); s.add_parser("export"); a=p.parse_args()
if a.command == "export": print(json.dumps(load_tokens(), indent=2, sort_keys=True))
elif a.command == "preview": print(json.dumps(preview_tokens(a.path), indent=2, sort_keys=True))
else:
    if a.command == "reset":
        override=Path(os.environ.get("LUMINA_CONFIG_HOME", Path.home()/".config/lumina"))/"palette-overrides.json"; override.unlink(missing_ok=True)
        current_file=Path.home()/"Pictures/Wallpapers/.current"; wallpaper=current_file.read_text(encoding="utf-8").strip() if current_file.exists() else None; tokens=apply_theme(wallpaper)
    else: tokens=apply_theme(a.wallpaper, color_temperature=a.temperature)
    toast("Theme updated from wallpaper", category="success")
