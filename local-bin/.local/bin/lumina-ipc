#!/usr/bin/env python3
from __future__ import annotations
import argparse, sys
from pathlib import Path
for p in (Path(__file__).resolve().parents[3]/"apps/lib",Path.home()/".local/share/lumina/lib"):
    if p.exists():sys.path.insert(0,str(p))
from lumina_core.ipc import emit_settings_changed
p=argparse.ArgumentParser(prog="lumina-ipc"); p.add_argument("key"); p.add_argument("value"); a=p.parse_args(); emit_settings_changed(a.key,a.value)
