{
  "theme.font.name": "Inter",
  "theme.font.size": "0.9rem",
  "theme.bar.floating": true,
  "theme.bar.transparent": true,
  "theme.bar.opacity": 92,
  "theme.bar.border_radius": "16px",
  "theme.bar.buttons.style": "split",
  "theme.bar.buttons.enableBorders": true,
  "theme.bar.buttons.monochrome": false,
  "theme.bar.menus.monochrome": false,
  "theme.osd.enable": true,
  "theme.osd.location": "top",
  "theme.osd.orientation": "horizontal",
  "theme.osd.opacity": 95,
  "theme.matugen": false,
  "notifications.position": "top right",
  "notifications.cache_actions": false,
  "menus.transition": "crossfade",
  "menus.transitionTime": 250,
  "bar.workspaces.show_icons": true,
  "bar.workspaces.show_numbered": false,
  "bar.workspaces.hideUnoccupied": true,
  "bar.clock.showIcon": false,
  "bar.clock.format": "%a %b %d  %I:%M %p",
  "bar.network.label": false,
  "bar.bluetooth.label": false,
  "bar.battery.hideLabelWhenFull": true,
  "bar.media.show_artist": false,
  "bar.media.show_active_only": true,
  "bar.media.truncation": true,
  "menus.clock.time.hideSeconds": true,
  "menus.clock.time.military": false,
  "menus.dashboard.directories.enabled": true,
  "menus.dashboard.controls.enabled": true,
  "menus.dashboard.stats.enable_gpu": false,
  "bar.layouts": {
    "0": {
      "left": [
        "dashboard",
        "workspaces",
        "windowtitle"
      ],
      "middle": [
        "media"
      ],
      "right": [
        "volume",
        "network",
        "bluetooth",
        "battery",
        "clock",
        "notifications"
      ]
    }
  }
}
