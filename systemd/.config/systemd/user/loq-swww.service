[Unit]
Description=Swww wallpaper daemon
PartOf=loq-session.target
StartLimitIntervalSec=30
StartLimitBurst=5
After=graphical-session.target
ConditionEnvironment=WAYLAND_DISPLAY

[Service]
Type=simple
ExecStart=/usr/bin/bash %h/.config/hypr/scripts/start-swww-daemon.sh
Restart=on-failure
RestartSec=1
TimeoutStopSec=5

[Install]
WantedBy=loq-session.target
